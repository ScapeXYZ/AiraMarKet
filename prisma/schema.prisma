datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model PendingMarket {
  id         Int      @id @default(autoincrement())
  title      String
  category   String
  expiry     String
  confidence Float
  sentiment  String
  status     String
  createdAt  DateTime @default(now())
}
